#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
ubuntu-wsl::check() { command -v ubuntu-wsl &> /dev/null; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
ubuntu-wsl::install()
{
	local result

	sudo apt-get -qq -y install ubuntu-wsl; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
ubuntu-wsl::remove()
{
	local result

	sudo apt-get -qq -y purge ubuntu-wsl; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
