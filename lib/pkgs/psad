# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
psad::check() { dpkg -l | grep psad 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
psad::install()
{
	local result

	sudo apt-get -qq -y install psad; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
psad::remove()
{
	local result

	sudo apt -qq -y purge psad; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
