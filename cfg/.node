# shellcheck shell=bash

NODE_IPv4="$(hostname -I)"
NODE_HOSTNAME="$(hostname -f)"
FW_ADMIN="127.0.0.1"
SSH_GRPS="sudo"
SSH_PORT="22"
ADMINEMAIL="root@localhost"
WINUSER="user"
NTPSERVERPOOL="0.ubuntu.pool.ntp.org 1.ubuntu.pool.ntp.org 2.ubuntu.pool.ntp.org 3.ubuntu.pool.ntp.org pool.ntp.org"
TIMEDATECTL="Brisbane/Australia"
AUDITD_MODE=1
APPLY="Y"
VERBOSE="N"
AUTOFILL="N"
KEEP_SNAPD="Y"
