# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
postfix::check() { dpkg -l | grep postfix 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
postfix::install()
{
	local result

	sudo apt-get -qq -y install postfix; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
postfix::config()
{
	local result

    sudo postconf -e disable_vrfy_command=yes
    sudo postconf -e smtpd_banner="\$myhostname ESMTP"
    sudo postconf -e smtpd_client_restrictions=permit_mynetworks,reject
    sudo postconf -e inet_interfaces=loopback-only

    sudo systemctl restart postfix.service; result=$?

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
postfix::remove()
{
	local result

	sudo apt -qq -y purge postfix; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
