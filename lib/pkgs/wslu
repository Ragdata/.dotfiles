#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
wslu::check() { dpkg -l | grep wslu 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
wslu::install()
{
	local result

	sudo apt-get -qq -y install wslu; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
wslu::remove()
{
	local result

	sudo apt-get -qq -y purge wslu; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
