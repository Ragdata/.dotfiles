#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
dos2unix::check() { dpkg -l | grep dos2unix 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
dos2unix::install()
{
	local result

	sudo apt-get -qq -y install dos2unix; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
dos2unix::remove()
{
	local result

	sudo apt -qq -y purge dos2unix; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
