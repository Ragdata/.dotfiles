#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
gnupg::check() { command -v gnupg &> /dev/null; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
gnupg::install()
{
	local result

	sudo apt-get -qq -y install gnupg; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
gnupg::remove()
{
	local result

	sudo apt-get -qq -y purge gnupg; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
