#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
composer::check() { if command -v composer &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
composer::install()
{
	local result

	sudo apt-get -qq -y install composer; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
composer::remove()
{
	local result

	sudo apt -qq -y purge composer; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
