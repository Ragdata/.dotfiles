script::rhosts()
{
    echoDot "[Hardening] .rhosts" -s "▶"

    while read -r hostpasswd
    do
        find "$hostpasswd" \( -name "hosts.equiv" -o -name ".rhosts" \) -exec rm -f {} \; 2> /dev/null
    done <<< "$(awk -F ":" '{print $6}' /etc/passwd)"

    [ -f /etc/hosts.equiv ] && sudo rm -f /etc/hosts.equiv

	return 0
}
