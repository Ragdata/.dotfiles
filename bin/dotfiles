#!/usr/bin/env bash
# shellcheck disable=SC1090
# shellcheck disable=SC1091
####################################################################
# dotfiles
####################################################################
# Ragdata's Dotfiles - Executable
#
# File:         dotfiles
# Author:       Ragdata
# Date:         23/08/2024
# License:      MIT License
# Repository:	https://github.com/Ragdata/.dotfiles
# Copyright:    Copyright © 2024 Redeyed Technologies
####################################################################
# PREFLIGHT
####################################################################
# capture stderr
# shellcheck disable=SC2093
#exec 2>>"$DOT_LOG/stderr.log"
# if script is called with 'debug' as the first argument, set debug mode
if [ "${1,,}" == "debug" ]; then
	shift
	DOT_DEBUG=1
fi
if [ "$DOT_DEBUG" -eq 1 ]; then
 	set -axeETo pipefail
	export LOG_LEVEL="DEBUG"
else
 	set -aeETo pipefail
fi
#set -aeETo pipefail
shopt -s inherit_errexit
####################################################################
# DEPENDENCIES
####################################################################
# metadata support
source "$DOTFILES/vendor/github.com/erichs/composure/composure.sh"
# error trap
#trap 'errorHandler "LINENO" "BASH_LINENO" "${BASH_COMMAND}" "$?"' ERR
# required library files
dot::include "dotfiles.functions"
####################################################################
# MAIN
####################################################################

case "${1:-}" in
	config)
		case "${2:-}" in
			pkg|package)
				dot::config::pkg "${3?}";;
		esac
		[ -z "$2" ] && menu::config
		;;
	disable)
		;;
	enable)
		;;
	help)
		;;
	install)
		case "${2:-}" in
			deps|dependencies)
				dot::install::deps;;
			pkg|package)
				dot::install::pkg "${3?}";;
		esac
		[ -z "$2" ] && menu::install
		;;
	migrate)
		;;
	preview)
		;;
	profile)
		;;
	remove)
		case "${2:-}" in
			pkg|package)
				dot::remove::pkg "${3?}";;
		esac
		;;
	restart)
		;;
	reload)
		;;
	set)
		dot::set;;
	search)
		;;
	show)
		;;
	update)
		case "${2:-}" in
			bin)
				dot::update::bin;;
			dots)
				dot::update::dots;;
			repo|sources)
				dot::update::repo;;
			sys|system)
				dot::update::sys;;
		esac
		[ -z "$2" ] && menu::update
		;;
	version)
		;;
esac

menu
