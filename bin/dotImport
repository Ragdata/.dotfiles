#!/usr/bin/env bash
# shellcheck disable=SC1090
####################################################################
# dotImport
####################################################################
# License:      MIT License
# Repository:	https://github.com/Ragdata/.dotfiles
# Copyright:    Copyright © 2024 Redeyed Technologies
####################################################################
# LOCAL FUNCTIONS
####################################################################
# ------------------------------------------------------------------
# strSplit
# ------------------------------------------------------------------
strSplit()
{
	local haystack="${1?}"
	local delim="${2?}"
	local -n arr="${3?}"
	# shellcheck disable=SC2034
	mapfile -d "$delim" -t arr < <(printf '%s' "$haystack")
}
# ------------------------------------------------------------------
# checkImported
# ------------------------------------------------------------------
checkImported()
{
	local path="${1?}"

	[[ ${IMPORTS[*]} =~ (^|[[:space:]])${path}([[:space:]]|$) ]] && returns 1

	return 0
}
####################################################################
# MAIN
####################################################################
(($# == 0)) && { echo "ERROR :: No file paths given"; exit 1; }

declare -ax ARR

for item in "$@"
do
	pathAvailable=""
	pathEnabled=""
	# let's start by breaking the target down (makes it easier later)
	if [[ "$item" == *"."* ]]; then
		strSplit "$item" "." ARR
	elif [[ "$item" == *"/"* ]]; then
		strSplit "$item" "/" ARR
	elif [[ "$item" == *" "* ]]; then
		strSplit "$item" " " ARR
	else
		match=0
		# which only leaves us with a couple of possibilities
		for path in "$PKGS" "$APPS"
		do
			if [ -f "$path/$item" ]; then
				match=1
				if ! checkImported "$path/$item"; then
					IMPORTS+=("$path/$item")
					source "$path/$item"
					break
				fi
			fi
		done
		# still no match?  Issue a warning and dump it
		if ((match == 0)); then
			echoWarning "'$item' not recognised"
			break
		fi
	fi
	# OK, let's inspect the second element and see what it can tell us
	if [ -n "${ARR[1]}" ]; then
		case "${ARR[1]}" in
			aliases)
				pathAvailable="$ALIASES/${ARR[0]}.aliases.bash"
				pathEnabled="$ALIASES/enabled/${ARR[0]}.aliases.bash"
				;;
			completions)
				pathAvailable="$COMPLETIONS/${ARR[0]}.completions.bash"
				pathEnabled="$COMPLETIONS/enabled/${ARR[0]}.completions.bash"
				;;
			functions)
				pathAvailable="$FUNCTIONS/${ARR[0]}.functions.bash"
				pathEnabled="$FUNCTIONS/enabled/${ARR[0]}.functions.bash"
				;;
			*)
				echoWarning "'$item' not recognised"
				;;
		esac
	fi
done
