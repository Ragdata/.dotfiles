#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
curl::check() { dpkg -l | grep curl 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
curl::install()
{
	local result

	sudo apt-get -qq -y install curl; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
curl::remove()
{
	local result

	sudo apt -qq -y purge curl; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
