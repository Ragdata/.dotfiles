#!/usr/bin/env bash
# shellcheck disable=SC1090
# shellcheck disable=SC1091
####################################################################
# dotfiles
####################################################################
# Ragdata's Dotfiles - Executable
#
# File:         dotfiles
# Author:       Ragdata
# Date:         23/08/2024
