# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
chrootkit::check() { dpkg -l | grep chrootkit 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
chrootkit::install()
{
	local result

	sudo apt-get -qq -y install chrootkit; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
chrootkit::remove()
{
	local result

	sudo apt -qq -y purge chrootkit; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
