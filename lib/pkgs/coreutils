#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
coreutils::check() { if command -v coreutils &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
coreutils::install()
{
	local result

	sudo apt-get -qq -y install coreutils; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
coreutils::remove()
{
	local result

	sudo apt -qq -y purge coreutils; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
