# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
vlock::check() { dpkg -l | grep vlock 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
vlock::install()
{
	local result

	sudo apt-get -qq -y install vlock; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
vlock::remove()
{
	local result

	sudo apt -qq -y purge vlock; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
