#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
shellcheck::check() { if command -v shellcheck &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
shellcheck::install()
{
	local result

	sudo apt-get -qq -y install shellcheck; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
shellcheck::remove()
{
	local result

	sudo apt -qq -y purge shellcheck; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
