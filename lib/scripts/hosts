script::hosts()
{
    echoLog "[Hardening] /etc/hosts.allow & /etc/hosts.deny" -S "▶"

    echo "sshd : ALL : ALLOW" | sudo tee /etc/hosts.allow
    echo "ALL: LOCAL, 127.0.0.1" | sudo tee -a /etc/hosts.allow
    echo "ALL: ALL" | sudo tee /etc/hosts.deny
    sudo chmod 644 /etc/hosts.allow
    sudo chmod 644 /etc/hosts.deny

	return 0
}
