# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
aide-common::check() { dpkg -l | grep aide-common 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
aide-common::install()
{
	local result

	sudo apt-get -qq -y install aide-common; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
aide-common::remove()
{
	local result

	sudo apt -qq -y purge aide-common; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
