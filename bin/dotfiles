#!/usr/bin/env bash
# shellcheck disable=SC1090
# shellcheck disable=SC1091
####################################################################
# dotfiles
####################################################################
# Ragdata's Dotfiles - Executable
#
# File:         dotfiles
# Author:       Ragdata
# Date:         23/08/2024
# License:      MIT License
# Repository:	https://github.com/Ragdata/.dotfiles
# Copyright:    Copyright © 2024 Redeyed Technologies
####################################################################
# PREFLIGHT
####################################################################
# capture stderr
# shellcheck disable=SC2093
#exec 2>>"$DOT_LOG/stderr.log"
# if script is called with 'debug' as the first argument, set debug mode
if [ "${1,,}" == "debug" ]; then
	shift
	DOT_DEBUG=1
fi
if [ "$DOT_DEBUG" -eq 1 ]; then
 	set -axETo pipefail
	export LOG_LEVEL="DEBUG"
else
 	set -aETo pipefail
fi
#set -aeETo pipefail
shopt -s inherit_errexit
####################################################################
# DEPENDENCIES
####################################################################
# metadata support
source "$DOTFILES/vendor/github.com/erichs/composure/composure.sh"
# error trap
#trap 'errorHandler "LINENO" "BASH_LINENO" "${BASH_COMMAND}" "$?"' ERR
# required library files
dot::include "dotfiles.functions"
####################################################################
# MAIN
####################################################################

case "${1:-}" in
	config)
		case "${2:-}" in
			pkg|package)
				dot::config::pkg "${3?}"; return
				;;
		esac
		[ -z "$2" ] && menu::config
		;;
    describe)
        case "${2:-}" in
            aliases)
                alias::describe; return
                ;;
            completions)
                completion::describe; return
                ;;
            functions)
                dot::describe::functions; return
                ;;
            instances)
                instance::describe; return
                ;;
            pkgs|packages)
                pkg::describe; return
                ;;
            plugins)
                plugin::describe; return
                ;;
            prompts)
                dot::describe::prompts; return
                ;;
            scripts)
                script::describe; return
                ;;
            stacks)
                stack::describe; return
                ;;
            *)
                exitLog "Unsupported component type '$2'"
                ;;
        esac
        ;;
	disable)
	    case "${2:-}" in
            alias)
                alias::disable "${3?}"; return
                ;;
            aliases)
                aliasDisable "${@:2}"; return
                ;;
            completion)
                completion::disable "${3?}"; return
                ;;
            completions)
                completionDisable "${@:2}"; return
                ;;
            plugin)
                plugin::disable "${3?}"; return
                ;;
            plugins)
                pluginDisable "${@:2}"; return
                ;;
            *)
                exitLog "Unsupported component type '$2'"
                ;;
	    esac
		;;
	enable)
	    case "${2:-}" in
            alias)
                alias::enable "${3?}"; return
                ;;
            aliases)
                aliasEnable "${@:2}"; return
                ;;
            completion)
                completion::enable "${3?}"; return
                ;;
            completions)
                completionEnable "${@:2}"; return
                ;;
            plugin)
                plugin::enable "${3?}"; return
                ;;
            plugins)
                pluginEnable "${@:2}"; return
                ;;
            *)
                exitLog "Unsupported component type '$2'"
                ;;
	    esac
		;;
	help)
		;;
	install)
		case "${2:-}" in
			deps|dependencies)
				dot::install::deps; return
				;;
			pkg|package)
				dot::install::pkg "${3?}"; return
				;;
            repos)
                dot::install::repos; return
                ;;
		esac
		[ -z "$2" ] && menu::install
		;;
	migrate)
		;;
	preview)
		;;
	profile)
		;;
	remove)
		case "${2:-}" in
			pkg|package)
				dot::remove::pkg "${3?}"; return
				;;
		esac
		;;
    reboot)
        dot::reboot
        ;;
	restart)
	    dot::restart
		;;
	reload)
	    dot::reload; return
		;;
	search)
		;;
	show)
		;;
	update)
		case "${2:-}" in
			bin)
				dot::update::bin
				;;
			dots)
				dot::update::dots
				;;
			repo|sources)
				dot::update::repo
				;;
			sys|system)
				dot::update::sys
				;;
		esac
		[ -z "$2" ] && menu::update
		;;
	version)
		;;
esac

menu
