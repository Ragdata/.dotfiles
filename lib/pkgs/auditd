#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
auditd::check() { dpkg -l | grep auditd 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
auditd::install()
{
	local result

	sudo apt-get -qq -y install auditd; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
auditd::remove()
{
	local result

	sudo apt -qq -y purge auditd; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
