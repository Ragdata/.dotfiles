####################################################################
# PREFLIGHT
####################################################################
# if script is called with 'debug' as the first argument, set debug mode
if [[ "${1,,}" == "debug" || "$DOT_DEBUG" == 1 ]]; then
	[ "${1,,}" == "debug" ] && shift
	DOT_DEBUG=1
	export LOG_LEVEL="DEBUG"
# 	set -axeETo pipefail
# else
# 	set -aeETo pipefail
fi
set -aeETo pipefail
shopt -s inherit_errexit
####################################################################
# DEPENDENCIES
####################################################################
# metadata support
source "$DOTFILES/vendor/github.com/erichs/composure/composure.sh"
# required library files
dot::include "dotfiles.functions"
####################################################################
# MAIN
####################################################################
verb="${1:-}"
component="${2:-}"

case "$verb" in
	enable)
		;;
	disable)
		;;
	help)
		;;
	install)
		dot::install::menu
		;;
	migrate)
		;;
	preview)
		;;
	profile)
		;;
	restart)
		;;
	reload)
		;;
	search)
		;;
	show)
		;;
	update)
		case "$component" in
			sys|system)		dot::sysUpdate;;
			*)				dot::update;;
		esac
		;;
	version)
		;;
	*)
		env
		;;
esac
