#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
zip::check() { if command -v zip &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
zip::install()
{
	local result

	sudo apt-get -qq -y install zip; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
zip::remove()
{
	local result

	sudo apt -qq -y purge zip; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
