# METADATA
####################################################################
about 'PyCharm-Community - Another top ranking, cross-platform IDE from Jetbrains'
group 'pkgs'
####################################################################
# FUNCTIONS
####################################################################
# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
pycharm-community::check() { sudo find /opt -type d -name 'pycharm-*' &> /dev/null; return $?; }
# ------------------------------------------------------------------
# INSTALL
# ------------------------------------------------------------------
pycharm-community::install()
{
    dot::include "alias.functions"

	local result path optPath dir

    [ "${#SEARCH_DOWNLOAD[@]}" -lt 2 ] && errorExit "Array mismatch ${SEARCH_DOWNLOAD[*]}"

    for dir in "${SEARCH_DOWNLOAD[@]}"
    do
        if [ -d "$dir" ]; then
            if find "$dir" -type f | grep -q "pycharm-"; then
                # shellcheck disable=SC2012
                path="$(find "$dir" -name 'pycharm-*' | head -n 1)"
                break
            fi
        fi
    done

    if [ -z "$path" ]; then
        wget -P "$HOME/Downloads" https://download-cdn.jetbrains.com/python/pycharm-community-2024.2.1.tar.gz &> /dev/null
        path="$(find "$HOME/Downloads" -name 'pycharm-*' | head -n 1)"
    fi

    chmod 0644 "$path"

    sudo tar -xzf "$path" -C /opt

    optPath="$(find /opt -type d -name 'pycharm-*' | head -n 1)"

    if [ ! -f "$CUSTOM/lib/aliases/jetbrains.aliases.bash" ]; then
        [ -d "$CUSTOM/lib/aliases" ] || { mkdir -p "$CUSTOM/lib/aliases" || exitLog "Unable to create directory '$CUSTOM/lib/aliases'"; }
        cp "$TEMPLATES/aliases.tmpl" "$CUSTOM/lib/aliases/jetbrains.aliases.bash"
    fi

    if ! grep -q "pycharm" "$CUSTOM/lib/aliases/jetbrains.aliases.bash"; then
        echo "alias pycharm=\"$optPath/bin/pycharm\"" >> "$CUSTOM/lib/aliases/jetbrains.aliases.bash"
    fi

    alias::enable "jetbrains"; result=$?

	return $result
}
# ------------------------------------------------------------------
# REMOVE
# ------------------------------------------------------------------
pycharm-community::remove()
{
    dot::include "alias.functions"

	local result

    optPath="$(find /opt -type d -name 'idea-IC-*' | head -n 1)"

    sed -i "/^.*pycharm.*/d" "$CUSTOM/lib/aliases/jetbrains.aliases.bash" &> /dev/null

    sudo rm -rf "$optPath"; result=$?

	return $result
}
