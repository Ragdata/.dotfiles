# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
systemd-coredump::check() { dpkg -l | grep systemd-coredump 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
systemd-coredump::install()
{
	local result

	sudo apt-get -qq -y install systemd-coredump; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
systemd-coredump::remove()
{
	local result

	sudo apt -qq -y purge systemd-coredump; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
