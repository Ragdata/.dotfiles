#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
procps::check() { if command -v procps &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
procps::install()
{
	local result

	sudo apt-get -qq -y install procps; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
procps::remove()
{
	local result

	sudo apt -qq -y purge procps; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
