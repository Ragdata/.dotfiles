#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
resolv::install() { return 0; }
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
resolv::config()
{
    if [ -f "$CUSTOM/etc/resolv.conf" ]; then
        source="$CUSTOM/etc/resolv.conf"
    else
        source="$DOT_ETC/resolv.conf"
    fi

    if [ -f "$source" ]; then
        sudo install -b -C -m 0644 -T "$source" /etc/resolv.conf
    fi

	return 0
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
resolv::remove() { return 0; }
