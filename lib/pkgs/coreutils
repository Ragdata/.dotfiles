#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
coreutils::check() { dpkg -l | grep coreutils 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
coreutils::install()
{
	local result

	sudo apt-get -qq -y install coreutils &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
coreutils::remove()
{
	local result

	  sudo apt-get -qq -y purge coreutils &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
