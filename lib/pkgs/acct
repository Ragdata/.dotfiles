# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
acct::check() { dpkg -l | grep acct 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
acct::install()
{
	local result

	sudo apt-get -qq -y install acct &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
acct::remove()
{
	local result

	sudo apt-get -qq -y purge acct &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
