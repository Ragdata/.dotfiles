# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
chrootkit::check() { dpkg -l | grep chrootkit 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
chrootkit::install()
{
	local result

	sudo apt-get -qq -y install chrootkit &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
chrootkit::remove()
{
	local result

	  sudo apt-get -qq -y purge chrootkit &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
