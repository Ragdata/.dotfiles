#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
net-tools::check() { if command -v ifconfig &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
net-tools::install()
{
	local result

	sudo apt-get -qq -y install net-tools; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
net-tools::remove()
{
	local result

	sudo apt -qq -y purge net-tools; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
