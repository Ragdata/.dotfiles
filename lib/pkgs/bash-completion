#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
bash-completion::check() { dpkg -l | grep bash-completion 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
bash-completion::install()
{
	local result

	sudo apt-get -qq -y install bash-completion; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
bash-completion::remove()
{
	local result

	sudo apt -qq -y purge bash-completion; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
