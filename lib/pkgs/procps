#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
procps::check() { dpkg -l | grep procps 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
procps::install()
{
	local result

	sudo apt-get -qq -y install procps; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
procps::remove()
{
	local result

	sudo apt -qq -y purge procps; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
