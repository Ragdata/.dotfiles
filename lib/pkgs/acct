# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
acct::check() { dpkg -l | grep acct 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
acct::install()
{
	local result

	sudo apt-get -qq -y install acct; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
acct::remove()
{
	local result

	sudo apt -qq -y purge acct; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
