#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
sysstat::check() { dpkg -l | grep sysstat 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
sysstat::install()
{
	local result

	sudo apt-get -qq -y install sysstat; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
sysstat::config()
{
	local result

	sudo sed -i '/^ENABLED.*/c\ENABLED="true"' /etc/default/sysstat

    sudo systemctl enable sysstat
    sudo systemctl start sysstat; result=$?

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
sysstat::remove()
{
	local result

	sudo apt -qq -y purge sysstat; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
