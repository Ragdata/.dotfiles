#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
unzip::check() { dpkg -l | grep unzip 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
unzip::install()
{
	local result

	sudo apt-get -qq -y install unzip &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
unzip::remove()
{
	local result

	  sudo apt-get -qq -y purge unzip &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
