# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
needrestart::check() { dpkg -l | grep needrestart 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
needrestart::install()
{
	local result

	sudo apt-get -qq -y install needrestart; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
needrestart::remove()
{
	local result

	sudo apt -qq -y purge needrestart; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
