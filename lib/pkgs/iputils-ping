#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
iputils-ping::check() { dpkg -l | grep iputils-ping 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
iputils-ping::install()
{
	local result

	sudo apt-get -qq -y install iputils-ping; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
iputils-ping::remove()
{
	local result

	sudo apt -qq -y purge iputils-ping; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
