# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
haveged::check() { dpkg -l | grep haveged 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
haveged::install()
{
	local result

	sudo apt-get -qq -y install haveged; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
haveged::remove()
{
	local result

	sudo apt -qq -y purge haveged; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
