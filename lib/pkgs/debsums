# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
debsums::check() { dpkg -l | grep debsums 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
debsums::install()
{
	local result

	sudo apt-get -qq -y install debsums; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
debsums::remove()
{
	local result

	sudo apt -qq -y purge debsums; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
