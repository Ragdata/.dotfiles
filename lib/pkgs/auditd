#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
auditd::check() { if command -v auditd &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
auditd::install()
{
	local result

	sudo apt-get -qq -y install auditd; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
auditd::remove()
{
	local result

	sudo apt -qq -y purge auditd; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
