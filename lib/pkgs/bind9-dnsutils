#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
bind9-dnsutils::check() { if command -v bind9-dnsutils &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
bind9-dnsutils::install()
{
	local result

	sudo apt-get -qq -y install bind9-dnsutils; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
bind9-dnsutils::remove()
{
	local result

	sudo apt -qq -y purge bind9-dnsutils; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
