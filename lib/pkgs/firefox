about 'Firefox web browser'
group 'pkgs'
label 'network'
####################################################################
# FUNCTIONS
####################################################################
#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
firefox::check() { dpkg -l | grep firefox 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
firefox::install()
{
	sudo snap install firefox &> /dev/null; result=$?

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
firefox::remove()
{
	local result gc="${1:-}"

    sudo snap remove firefox &> /dev/null; result=$?

	return $result
}
