# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
openssh-server::check() { dpkg -l | grep openssh-server 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
openssh-server::install()
{
	local result

	sudo apt-get -qq -y install openssh-server; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
openssh-server::remove()
{
	local result

	sudo apt -qq -y purge openssh-server; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
