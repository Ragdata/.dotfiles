# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
rkhunter::check() { dpkg -l | grep rkhunter 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
rkhunter::install()
{
	local result

	sudo apt-get -qq -y install rkhunter; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
rkhunter::remove()
{
	local result

	sudo apt -qq -y purge rkhunter; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
