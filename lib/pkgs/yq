# METADATA
####################################################################
about 'A lightweight and portable command-line YAML, JSON, and XML processor'
group 'pkgs'
label 'utility'
####################################################################
# FUNCTIONS
####################################################################
#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
yq::check() { dpkg -l | grep yq 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
yq::install()
{
	local result gc="${1:-}"

	sudo apt-get -qq -y install yq &> /dev/null; result=$?
	if [ -z "$gc" ]; then sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null; fi

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
yq::remove()
{
	local result gc="${1:-}"

	sudo apt-get -qq -y purge yq &> /dev/null; result=$?
	if [ -z "$gc" ]; then sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null; fi

	return $result
}
