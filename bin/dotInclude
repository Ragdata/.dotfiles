####################################################################
# LOCAL FUNCTIONS
####################################################################
# ------------------------------------------------------------------
# _checkIncluded
# ------------------------------------------------------------------
_checkIncluded()
{
	local path="${1?}"

	[[ ${IMPORTS[*]} =~ (^|[[:space:]])${path}([[:space:]]|$) ]] && returns 1

	return 0
}
# ------------------------------------------------------------------
# _echoWarning
# ------------------------------------------------------------------
_echoWarning()		{ echoAlias "${SYMBOL_WARNING} $1" -c "${GOLD}" "${@:2}"; }
# ------------------------------------------------------------------
# strSplit
# ------------------------------------------------------------------
_strSplit()
{
	local haystack="${1?}"
	local delim="${2?}"
	local -n arr="${3?}"
	# shellcheck disable=SC2034
	mapfile -d "$delim" -t arr < <(printf '%s' "$haystack")
}
####################################################################
# MAIN
####################################################################
(($# == 0)) && { echo "ERROR :: No file paths given"; exit 1; }

declare -ax ARR

for item in "$@"
do
	pathAvailable=""
	pathEnabled=""
	# let's start by breaking the target down (makes it easier later)
	if [[ "$item" == *"."* ]]; then
		_strSplit "$item" "." ARR
	elif [[ "$item" == *"/"* ]]; then
		_strSplit "$item" "/" ARR
	elif [[ "$item" == *" "* ]]; then
		_strSplit "$item" " " ARR
	else
		match=0
		# which only leaves us with a couple of possibilities
		for path in "$PKGS" "$APPS"
		do
			if [ -f "$path/$item" ]; then
				match=1
				if ! _checkIncluded "$path/$item"; then
						IMPORTS+=("$path/$item")
						source "$path/$item"
						break
				fi
			fi
		done
		# still no match?  Issue a warning and dump it
		if ((match == 0)); then
			_echoWarning "'$item' not recognised"
			break
		fi
	fi
	# OK, let's inspect the second element and see what it can tell us
	if [ -n "${ARR[1]}" ]; then
		case "${ARR[1]}" in
			alias|aliases)
				pathAvailable="$ALIASES/${ARR[0]}.aliases.bash"
				pathEnabled="$DOT_REG/enabled/${ARR[0]}.aliases.bash"
				;;
			completion|completions)
				pathAvailable="$COMPLETIONS/${ARR[0]}.completions.bash"
				pathEnabled="$DOT_REG/enabled/${ARR[0]}.completions.bash"
				;;
			function|functions)
				pathAvailable="$FUNCTIONS/${ARR[0]}.functions.bash"
				pathEnabled="$DOT_REG/enabled/${ARR[0]}.functions.bash"
				;;
			plugin|plugins)
				pathAvailable="$PLUGINS/${ARR[0]}.plugin.bash"
				pathEnabled="$DOT_REG/enabled/${ARR[0]}.plugin.bash"
				;;
			*)	_echoWarning "'$item' not recognised";;
		esac
	fi
	[ -f "$pathEnabled" ] && source "$pathEnabled"
	[ -f "$pathAvailable" ] && errorExit "'$item' has not been enabled under your current profile"
done
