#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
fstab::install() { return 0; }
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
fstab::config()
{
    if [ -f "$DOT_ETC/fstab" ]; then
        sudo install -b -C -m 0644 -T "$DOT_ETC/fstab" /etc/fstab
    fi

	return 0
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
fstab::remove() { return 0; }
