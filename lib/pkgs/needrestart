# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
needrestart::check() { dpkg -l | grep needrestart 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
needrestart::install()
{
	local result

	sudo apt-get -qq -y install needrestart &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
needrestart::remove()
{
	local result

	  sudo apt-get -qq -y purge needrestart &> /dev/null; result=$?
	sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null

	return $result
}
