about 'DNS client programs derived from the BIND9 source tree'
group 'pkgs'
####################################################################
# FUNCTIONS
####################################################################
#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
bind9-dnsutils::check() { dpkg -l | grep bind9-dnsutils 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
bind9-dnsutils::install()
{
	local result gc="${1:-}"

	sudo apt-get -qq -y install bind9-dnsutils &> /dev/null; result=$?
	if [ -z "$gc" ]; then sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null; fi

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
bind9-dnsutils::remove()
{
	local result gc="${1:-}"

	  sudo apt-get -qq -y purge bind9-dnsutils &> /dev/null; result=$?
	if [ -z "$gc" ]; then sudo apt-get -qq -y clean &> /dev/null && sudo apt-get -qq -y autoremove &> /dev/null; fi

	return $result
}
