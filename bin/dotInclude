(($# == 0)) && errorExit "ERROR :: No file paths given"

declare -ax ARR

for item in "$@"
do
	match=0
	pathAvailable=""
	pathEnabled=""
	# let's start by breaking the target down
	if [[ "$item" == *"."* ]]; then
		str::split "$item" "." ARR
	elif [[ "$item" == *"/"* ]]; then
		str::split "$item" "/" ARR
	elif [[ "$item" == *" "* ]]; then
		str::split "$item" " " ARR
	else
	fi
done

