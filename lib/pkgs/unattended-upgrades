#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
unattended-upgrades::install()
{
	local result

	sudo apt-get -qq -y install unattended-upgrades; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
unattended-upgrades::config()
{
	local result

    sudo dpkg-reconfigure -plow unattended-upgrades; result=$?

    return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
unattended-upgrades::remove()
{
	local result

	sudo apt -qq -y purge unattended-upgrades; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
