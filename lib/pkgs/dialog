#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
dialog::check() { dpkg -l | grep dialog 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
dialog::install()
{
	local result

	sudo apt-get -qq -y install dialog; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
dialog::config()
{
	local result

	if [ -f "$DOT_CFG/.dialogrc" ]; then
		install -v -b -C -D -t "$HOME" "$DOT_CFG/.dialogrc"; result="$?"
	else
		result=1
	fi
	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
dialog::remove()
{
	local result

	sudo apt -qq -y purge dialog; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
