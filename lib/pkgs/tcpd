# ------------------------------------------------------------------
# CHECK
# ------------------------------------------------------------------
tcpd::check() { dpkg -l | grep tcpd 2> /dev/null 1>&2; return $?; }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
tcpd::install()
{
	local result

	sudo apt-get -qq -y install tcpd; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
tcpd::remove()
{
	local result

	sudo apt -qq -y purge tcpd; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
