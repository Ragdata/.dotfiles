wsl::install() { return 0; }
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
wsl::config()
{
    if [ -f "$DOT_ETC/wsl.conf" ]; then
        sudo install -b -C -m 0644 -T "$DOT_ETC/wsl.conf" /etc/wsl.conf
    fi

	return 0
}
