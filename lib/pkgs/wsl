#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
wsl::install() { return 0; }
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
wsl::config()
{
    if [ -f "$CUSTOM/etc/wsl.conf" ]; then
        source="$CUSTOM/etc/wsl.conf"
    else
        source="$DOT_ETC/wsl.conf"
    fi

    if [ -f "$source" ]; then
        sudo install -b -C -m 0644 -T "$source" /etc/wsl.conf
    fi

	return 0
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
wsl::remove() { return 0; }
