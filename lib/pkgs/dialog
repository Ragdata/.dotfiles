#-------------------------------------------------------------------
# CHECK
#-------------------------------------------------------------------
dialog::check() { if command -v dialog &> /dev/null; then return 0; else return 1; fi }
#-------------------------------------------------------------------
# INSTALL
#-------------------------------------------------------------------
dialog::install()
{
	local result

	sudo apt-get -qq -y install dialog; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
#-------------------------------------------------------------------
# CONFIG
#-------------------------------------------------------------------
dialog::config()
{
	local result

	if [ -f "$DOT_CFG/.dialogrc" ]; then
		install -v -b -C -D -t "$HOME" "$DOT_CFG/.dialogrc"; result="$?"
	else
		result=1
	fi
	return $result
}
#-------------------------------------------------------------------
# REMOVE
#-------------------------------------------------------------------
dialog::remove()
{
	local result

	sudo apt -qq -y purge dialog; result=$?
	sudo apt-get -qq -y clean && sudo apt-get -qq -y autoremove

	return $result
}
